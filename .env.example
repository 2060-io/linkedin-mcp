# --- LinkedIn app credentials (Developer Portal) ---
# Enable the "Sign In with LinkedIn using OpenID Connect" and "Share on LinkedIn"
# products on your app to obtain the openid/profile/email + w_member_social scopes.
LINKEDIN_CLIENT_ID=your_client_id_here
LINKEDIN_CLIENT_SECRET=your_client_secret_here

# Must EXACTLY match a Redirect URL configured on the LinkedIn app.
# Deployment (option b): https://<public-host>/oauth/callback
# Local dev (npm run auth): http://localhost:8000/oauth/callback
LINKEDIN_REDIRECT_URI=http://localhost:8000/oauth/callback

# LinkedIn-Version header (YYYYMM). Pin it; bump deliberately.
LINKEDIN_API_VERSION=202506

# --- OAuth admin endpoint Basic Auth (protects /oauth/*) ---
# Required to enable the cluster-hosted OAuth routes. If unset, /oauth/* is disabled.
LI_MCP_ADMIN_USER=admin
LI_MCP_ADMIN_PASSWORD=change_me

# --- Member token (optional) ---
# Normally minted via /oauth/start (HTTP) or `npm run auth` (local) and persisted to the
# state file, then refreshed automatically. Set these only to seed an existing token.
# LINKEDIN_ACCESS_TOKEN=
# LINKEDIN_REFRESH_TOKEN=
# LINKEDIN_PERSON_URN=urn:li:person:xxxx

# --- Safety features (all optional) ---
# Daily budget limits. 0 disables an action, -1 = unlimited.
# LI_MCP_MAX_POSTS=5
# LI_MCP_MAX_COMMENTS=10
# LI_MCP_MAX_REACTIONS=30
# LI_MCP_MAX_DELETES=3

# TOON encoding — token-efficient output. Default: true ("false" for JSON).
# LI_MCP_TOON=true
# Compact responses — strip verbose fields. Default: true.
# LI_MCP_COMPACT=true
# Engagement dedup — never comment/react on the same post twice. Default: true.
# LI_MCP_DEDUP=true

# State file path. Default: {cwd}/linkedin-mcp-state.json
# For k8s, point this at a mounted PVC so tokens + budgets survive restarts.
# LI_MCP_STATE_FILE=/data/linkedin-mcp-state.json

# --- MCP transport ---
# stdio (default) or http
MCP_TRANSPORT=stdio
MCP_PORT=8000
MCP_PATH=/mcp
MCP_HEALTH_PATH=/healthz
MCP_BODY_LIMIT=50mb
# Public base URL of the deployed server (used to build OAuth redirect when behind a proxy).
# MCP_PUBLIC_URL=https://linkedin-mcp.example.com
